{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "QuestifyApi",
    "Audience": "QuestifyClient",
    "SigningKey": "QuestifySuperSecretSigningKey_ChangeInProduction_32CharsMin!",
    "ExpirationMinutes": 60
  },
  "EmailSettings": {
    "SenderEmail": "your-email@gmail.com",
    "AppPassword": "your-app-password"
  }
}
